{
  "name": "shiwas",
  "version": "1.0.0",
  "description": "Framework-agnostic SWR library with adapters for React, Svelte, Solid, and Vue",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs"
    },
    "./react": {
      "types": "./dist/adapters/react/index.d.ts",
      "import": "./dist/adapters/react/index.js",
      "require": "./dist/adapters/react/index.cjs"
    },
    "./svelte": {
      "types": "./dist/adapters/svelte/index.d.ts",
      "import": "./dist/adapters/svelte/index.js",
      "require": "./dist/adapters/svelte/index.cjs"
    },
    "./solid": {
      "types": "./dist/adapters/solid/index.d.ts",
      "import": "./dist/adapters/solid/index.js",
      "require": "./dist/adapters/solid/index.cjs"
    },
    "./vue": {
      "types": "./dist/adapters/vue/index.d.ts",
      "import": "./dist/adapters/vue/index.js",
      "require": "./dist/adapters/vue/index.cjs"
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "types:check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/use-sync-external-store": "^1.5.0",
    "react": "^18.0.0",
    "rollup": "^4.0.0",
    "solid-js": "^1.8.0",
    "svelte": "^4.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.3.3",
    "use-sync-external-store": "^1.2.0",
    "vite": "^5.0.0",
    "vitest": "^1.2.2",
    "vue": "^3.4.0"
  },
  "peerDependencies": {
    "typescript": "^5",
    "react": ">=16.8.0",
    "solid-js": ">=1.0.0",
    "svelte": ">=3.0.0",
    "vue": ">=3.0.0"
  },
  "keywords": [
    "swr",
    "cache",
    "fetch",
    "data-fetching",
    "stale-while-revalidate",
    "react",
    "svelte",
    "solid",
    "vue",
    "framework-agnostic"
  ],
  "author": "shishant biswas",
  "license": "MIT"
}